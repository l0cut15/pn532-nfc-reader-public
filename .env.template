# Home Assistant Configuration
HA_HOST=YOUR_HA_IP_ADDRESS
HA_PORT=8123
HA_TOKEN=your_long_lived_access_token_here

# NFC Reader Configuration
NFC_BAUDRATE=115200
NFC_LOCATION=Living Room
NFC_READER_ID=nfc_reader_main
NFC_READER_NAME=Main NFC Reader
NFC_TIMEOUT=1.0

# Auto-detect: set to true to probe all /dev/ttyUSB* ports for a PN532 at startup.
# Set to false and specify NFC_PORT for a fixed device path (useful for Docker or
# systems with multiple USB serial devices where auto-detection could be ambiguous).
NFC_AUTO_DETECT=true
NFC_PORT=

# WebSocket mode (recommended): mirrors what the official iOS/Android apps do.
# Delivers scans via mobile_app webhook → tag.async_scan_tag() → updates Tags panel,
# tag.<id> entity state, and device registry in Home Assistant.
# Set to false to fall back to the legacy REST POST /api/events/tag_scanned path.
HA_WS_ENABLED=true

# WebSocket tuning
HA_WS_HEARTBEAT=30
HA_WS_RECONNECT_MAX=60

# Device name shown in HA Settings → Devices & Services after registration
DEVICE_NAME=PN532 NFC Reader

# Offline scan queue: scans received while WS is down are queued and replayed on reconnect.
SCAN_QUEUE_MAX=50
SCAN_STALE_SECONDS=300
